# Supabase settings
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are automatically provided in Edge Functions deployed to Supabase.
# For local testing, you can use:
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# LINE Messaging API settings
# Create a Channel at LINE Developers Console (Messaging API type)
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# The room/group where the 'overall' combined summary should be sent
LINE_OVERALL_ROOM_ID=your-test-group-id-or-room-id

# Groq configuration
GROQ_API_KEY=gsk-your-groq-api-key

# Admin dashboard auth token (required for /functions/v1/admin-api)
ADMIN_DASHBOARD_TOKEN=change-this-to-a-long-random-token

# Cron invoker auth token (recommended for DB cron -> Edge auth)
CRON_AUTH_TOKEN=change-this-to-a-long-random-token
